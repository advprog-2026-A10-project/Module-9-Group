@startuml
title Individual Component Diagram - Auth Settings Security
left to right direction
skinparam componentStyle rectangle
skinparam linetype ortho
skinparam nodesep 55
skinparam ranksep 70
skinparam wrapWidth 200
skinparam packageStyle rectangle

package "Auth Frontend Container" as AuthFE <<Frontend>> {
  component "Settings Pages\nprofile-page\nsecurity-page\nsessions-page\nnotifications-page\nmfa-page" as Pages <<Presentation>>
  component "Settings Hooks\nuseGetMfaStatusQuery\nuseChangePasswordMutation\nuseGetSessionsQuery\nuseUpdateNotificationPreferencesMutation" as Hooks <<Hooks>>
  component "Settings Use Cases\nGetMfaStatusUseCase\nChangePasswordUseCase\nGetSessionsUseCase\nUpdateNotificationPreferencesUseCase" as FEUseCases <<Use Case>>
  component "SettingsApiRepository" as SettingsApiRepo <<Repository>>
  component "apiClient\nBearer access token" as ApiClient <<HTTP Client>>
  component "Zod settings schemas\nsettings-api/schemas.ts" as ZodSchemas <<Validation>>
}

package "Auth Backend Container" as AuthBE <<Backend>> {
  component "Settings/Auth Controllers\nget_profile\nupdate_profile\nchange_password\nget_sessions\nrevoke_session\nrevoke_all_sessions\nget_notification_preferences\nupdate_notification_preferences\nget_mfa_settings" as Controllers <<Controller>>
  component "AuthenticatedUser\nJWT/session extractor" as AuthExtractor <<Middleware>>
  component "AuthMfaUseCase\nsettings and MFA use cases" as AuthMfa <<Use Case>>
  component "PostgreSQL Repositories\nPostgresUserRepository\nPostgresSessionRepository\nPostgresNotificationPreferencesRepository\nPostgresEmailMfaCodeRepository\nPostgresTotpSetupRepository" as AuthRepos <<Repository>>
  component "Security and Email Services\nScryptPasswordHasher\nTotpRsService\nResendVerificationEmailSender" as AuthServices <<Service>>
}

database "Auth PostgreSQL\nauth-db owned by auth-be" as AuthDB <<Database>>
cloud "Resend Email Provider" as Resend <<External System>>

Pages --> Hooks
Hooks --> FEUseCases
FEUseCases --> SettingsApiRepo
SettingsApiRepo --> ZodSchemas
SettingsApiRepo --> ApiClient
ApiClient --> Controllers

Controllers --> AuthExtractor
Controllers --> AuthMfa
AuthMfa --> AuthRepos
AuthMfa --> AuthServices
AuthRepos --> AuthDB
AuthServices --> Resend

note bottom of AuthDB
This individual diagram expands only auth-fe -> auth-be -> auth-db.
end note
@enduml
